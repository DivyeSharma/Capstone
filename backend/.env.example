# Smart Yield Express Backend - Environment Variables Template

# Port configuration
PORT=5001

# MongoDB Connection URIs (both are supported for flexibility in cloud hosts)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart-yield?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart-yield?retryWrites=true&w=majority

# JWT Token Secret
JWT_SECRET=your_jwt_secret_key_change_in_production

# Target URL for the Python/Flask ML service
ML_API_URL=http://localhost:5000

# Environment Mode ('production' or 'development')
NODE_ENV=production

# Permitted Frontend Domains (comma-separated list for production CORS whitelist)
CORS_ORIGIN=https://your-frontend-subdomain.up.railway.app

# Gmail SMTP Email Server Configurations (Optional, for notifications)
EMAIL_USER=example@gmail.com
EMAIL_PASS=smtp_app_password
ADMIN_EMAIL=example@gmail.com
